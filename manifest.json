{
    "author": "g-shifu",
    "name": "股票基金助手-V3",
    "description": "股票基金助手已适配新Chrome浏览器",
    "version": "3.4.1",
    "manifest_version": 3,
    "icons": {
        "16": "icons/logo-128.png",
        "48": "icons/logo-128.png",
        "128": "icons/logo-128.png"
    },
    "homepage_url": "https://github.com/g-shifu/stock-chrome-plugin",
    "action": {
        "default_icon": {
            "19": "icons/logo-128.png",
            "38": "icons/logo-128.png"
        },
        "default_title": "股票基金助手-V3",
        "default_popup": "popup/popup.html"
    },
    "content_scripts": [
        {
            "matches": [
                "*://pu_shu.gitee.io/*",
                "*://*.topnamei.top/*",
                "*://*.hqzs.top/*",
                "*://*.githud.top/*"
            ],
            "js": [
                "contentjs/index.js"
            ]
        }
    ],
    "options_page": "options/options.html",
    "options_ui": {
        "page": "options/options.html"
    },
    "content_security_policy": {
        "extension_pages": "script-src 'self'; object-src 'self';"
    },
    "background": {
        "service_worker": "background.js"
    },
    "permissions": [
        "contextMenus",
        "storage",
        "notifications",
        "declarativeNetRequest",
        "declarativeNetRequestWithHostAccess"
    ],
    "host_permissions": [
        "https://*.eastmoney.com/*",
        "https://*.gitee.io/*",
        "https://topnamei.top/*",
        "https://fundmobapi.eastmoney.com/*",
        "https://fundgz.1234567.com.cn/*"
    ]
}